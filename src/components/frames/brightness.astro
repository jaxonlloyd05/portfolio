---
const { src, id, size, fill } = Astro.props
---

<div>
    <canvas id={id} width={size[0]} height={size[1]}></canvas>
</div>

<script define:vars={{ src, id, fill }} lang='ts'>
    const canvas = document.querySelector(`#${id}`);
    const ctx = canvas.getContext('2d');
    const width = canvas.width 
    const height = canvas.height;

    const spacing_opts = { high: 6, low: 4 };

    let pixels = [];
    let spacing = spacing_opts.high;
    
    const img = new Image();
    img.src = src;
    img.onload = () => {
        const dummy = document.createElement('canvas');
        dummy.height = height;
        dummy.width = width;
        
        const dummy_ctx = dummy.getContext('2d');
        dummy_ctx.drawImage(img, 0, 0, width, height);
        pixels = dummy_ctx.getImageData(0, 0, width, height).data;
        draw();
    }

    const get_color = (x, y) => {
        const cx = Math.max(0, Math.min(width - 1, Math.floor(x)));
        const cy = Math.max(0, Math.min(height - 1, Math.floor(y)));
        const i = (cy * width + cx) * 4;

        return [  pixels[i], pixels[i + 1], pixels[i + 2], pixels[i + 3] ];
    }

    const get_brightness = (r, g, b) => {
        return 0.299 * r + 0.587 * g + 0.114 * b;
    };
    
    let dot_count = 0;
    const dot = (x, y) => {
        dot_count += 1;
        const [ r, g, b, a ] = get_color(x, y);
        const brightness = get_brightness(r, g, b)

        ctx.beginPath();
        ctx.fillStyle = `rgba(${r},${g},${b},${a})`;
        ctx.fillText(brightness, x, y)
        ctx.fill();
    }

    const draw = () => {
        ctx.clearRect(0, 0, width, height);
        if (!pixels) { return; }
        
        for (let ny = spacing / 2; ny < height; ny += spacing ) {
            for (let nx = spacing / 2; nx < width; nx += spacing) {
                dot(nx-(1.5*spacing), ny+spacing);
            }
        }
    }
    
</script>